#!/usr/bin/env bash
# rack — download, install, and remove GitHub binaries/archives by name
# Usage:
#   rack [-a] <name> <url|slug>   Install a binary (full URL, owner/repo, or repo name)
#   rack -u <name> [url|slug]     Update a managed binary (optionally from new URL or slug)
#   rack -r <name> <index>        Roll back to a previously recorded URL
#   rack -H <name>                Show URL history for a managed binary
#   rack -R <name>                Remove a previously installed binary
#   rack -l                       List all managed installs
#   rack update [-y] [-n]         Check for and apply updates for all managed installs

set -euo pipefail

INSTALL_DIR="${RACK_DIR:-$HOME/.local/bin}"
REGISTRY="${RACK_REGISTRY:-$HOME/.local/share/rack/registry.tsv}"
HISTORY="${RACK_HISTORY:-$HOME/.local/share/rack/history.tsv}"

# ── colors & formatting ───────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  YELLOW="\033[1;33m"
  CYAN="\033[1;36m"
  RED="\033[1;31m"
  RESET="\033[0m"
else
  BOLD="" DIM="" GREEN="" YELLOW="" CYAN="" RED="" RESET=""
fi

# ── helpers ───────────────────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}rack${RESET} — install and remove GitHub binaries by name"
  echo ""
  echo -e "${BOLD}Usage:${RESET}"
  echo -e "  rack ${CYAN}[-a] [-A arch]${RESET} ${CYAN}<name> <url|slug>${RESET}  Download and install a binary"
  echo -e "  rack ${CYAN}-u${RESET} ${CYAN}<name> [url|slug]${RESET}          Update a managed binary (optionally from new URL or slug)"
  echo -e "  rack ${CYAN}-r${RESET} ${CYAN}<name> <index>${RESET}              Roll back to a previously recorded URL"
  echo -e "  rack ${CYAN}-H${RESET} ${CYAN}<name>${RESET}                      Show URL history for a managed binary"
  echo -e "  rack ${CYAN}-R${RESET} ${CYAN}<name>${RESET}                      Remove a managed install"
  echo -e "  rack ${CYAN}-l${RESET}                             List all managed installs"
  echo -e "  rack ${CYAN}update [-y]${RESET}                   Check for and apply updates for all managed installs"
  echo -e "  rack ${CYAN}export [file]${RESET}                 Export registry (stdout or file)"
  echo -e "  rack ${CYAN}import <file>${RESET}                 Import/merge registry from file"
  echo ""
  echo -e "${BOLD}Flags:${RESET}"
  echo -e "  ${CYAN}-a${RESET}         Extract archive and find binary named <name> inside"
  echo -e "  ${CYAN}-A${RESET} ${CYAN}<arch>${RESET}  Override arch filter (default: auto-detect from uname -m)"
  echo -e "  ${CYAN}-y${RESET}         Auto-confirm prompts (useful for scripting rack update)"
  echo -e "  ${CYAN}-n${RESET}         Dry-run: resolve and plan but do not download or write anything"
  echo -e "  ${CYAN}-u${RESET}         Update binary from its recorded source URL (or a new one)"
  echo -e "  ${CYAN}-r${RESET}         Roll back to a URL from history by index (see rack -H <name>)"
  echo -e "  ${CYAN}-H${RESET}         Show numbered URL history for a binary"
  echo -e "  ${CYAN}-R${RESET}         Remove the named binary from the install dir"
  echo -e "  ${CYAN}-l${RESET}         List everything managed by rack"
  echo ""
  echo -e "  Supported archives: .tar.gz  .tgz  .tar.bz2  .tar.xz  .zip"
  echo -e "  GitHub slugs:  ${DIM}owner/repo${RESET}  ${DIM}(resolves latest release, auto-filters assets by platform)${RESET}"
  echo -e "                 ${DIM}repo-name${RESET}    ${DIM}(searches GitHub, then resolves)${RESET}"
  echo -e "  Install dir:   ${DIM}${INSTALL_DIR}${RESET}"
  echo -e "  Registry:      ${DIM}${REGISTRY}${RESET}"
  echo -e "  History:       ${DIM}${HISTORY}${RESET}"
  echo -e "  Override dirs: ${DIM}export RACK_DIR=/your/path${RESET}"
  echo -e "                 ${DIM}export RACK_HISTORY=/your/path${RESET}"
  exit 1
}

die() {
  echo -e "\n${RED}✖ error:${RESET} $*" >&2
  exit 1
}

step() {
  echo -e "\n${CYAN}::${RESET} ${BOLD}$*${RESET}"
}

info() {
  echo -e "   ${DIM}$*${RESET}"
}

ok() {
  echo -e "   ${GREEN}✔${RESET} $*"
}

warn() {
  echo -e "   ${YELLOW}⚠${RESET}  $*"
}

validate_name() {
  local n="$1"
  if [[ -z "$n" || "$n" == "." || "$n" == ".." || "$n" == -* || "$n" == */* || ! "$n" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
    die "Invalid name '${n}'. Use only letters, numbers, dots, dashes, underscores; must start with alphanum; reject '.' and '..'."
  fi
}

# Populates CONFLICT_PATH (and optionally CONFLICT_PKG) when <name> resolves to an
# existing command outside the rack install directory.
_detect_name_conflict() {
  local n="$1"
  CONFLICT_PATH=""
  CONFLICT_PKG=""

  local existing=""
  existing="$(command -v "$n" 2>/dev/null || true)"
  [[ -z "$existing" ]] && return 1

  local target="${INSTALL_DIR}/${n}"
  [[ "$existing" == "$target" ]] && return 1
  case "$existing" in
    "${INSTALL_DIR}"/*) return 1 ;;
  esac

  CONFLICT_PATH="$existing"
  CONFLICT_PKG="$(_package_for_path "$existing")"
  return 0
}

_package_for_path() {
  local p="$1" out=""
  if command -v pacman &>/dev/null; then
    out="$(pacman -Qo "$p" 2>/dev/null | sed -n 's/.* owned by \([^ ]*\).*/\1/p' | head -n1)"
  elif command -v dpkg &>/dev/null; then
    out="$(dpkg -S "$p" 2>/dev/null | cut -d: -f1 | head -n1)"
  elif command -v rpm &>/dev/null; then
    out="$(rpm -qf "$p" 2>/dev/null | head -n1)"
  elif command -v apk &>/dev/null; then
    out="$(apk info -W "$p" 2>/dev/null | head -n1)"
  fi
  printf '%s' "$out"
}

# When NAME conflicts with a system command, prompt to shadow it or pick a new name.
# Mutates global NAME on success.
resolve_name_conflict() {
  if ! _detect_name_conflict "$NAME"; then
    return 0
  fi

  if [[ "${DRY_RUN:-false}" == true ]]; then
    warn "Name '${NAME}' conflicts with existing command: ${CONFLICT_PATH}"
    [[ -n "$CONFLICT_PKG" ]] && info "Package: ${CONFLICT_PKG}"
    info "Dry run — conflict resolution skipped"
    return 0
  fi

  if [[ "${YES_MODE:-false}" == true ]]; then
    warn "Name '${NAME}' conflicts with ${CONFLICT_PATH} — auto-shadowing (-y)"
    [[ -n "$CONFLICT_PKG" ]] && info "Package: ${CONFLICT_PKG}"
    return 0
  fi

  if [[ ! -t 0 ]]; then
    die "Name '${NAME}' conflicts with existing command '${CONFLICT_PATH}'. Run interactively to shadow it or choose a different name."
  fi

  step "Name conflict"
  warn "'${NAME}' already exists on your system: ${CONFLICT_PATH}"
  [[ -n "$CONFLICT_PKG" ]] && info "Provided by package: ${CONFLICT_PKG}"
  echo ""
  echo -e "   ${CYAN}1)${RESET}  Shadow — install as '${NAME}' to ${INSTALL_DIR}"
  echo -e "       ${DIM}(takes precedence when ${INSTALL_DIR} appears before system paths in PATH)${RESET}"
  echo -e "   ${CYAN}2)${RESET}  Pick a different name"
  echo ""

  local choice new_name
  while true; do
    printf "   ${BOLD}Choice [1/2]:${RESET} "
    read -r choice < /dev/tty
    case "$choice" in
      1)
        ok "Will shadow existing command as '${NAME}'"
        if [[ ":$PATH:" != *":${INSTALL_DIR}:"* ]]; then
          warn "Shadowing requires '${INSTALL_DIR}' to be in your PATH."
        fi
        return 0
        ;;
      2)
        while true; do
          printf "   ${BOLD}New name:${RESET} "
          read -r new_name < /dev/tty
          validate_name "$new_name"
          if _detect_name_conflict "$new_name"; then
            warn "'${new_name}' also conflicts with ${CONFLICT_PATH} — try another."
          elif [[ -f "${INSTALL_DIR}/${new_name}" ]]; then
            warn "'${new_name}' already exists in ${INSTALL_DIR} — try another."
          else
            NAME="$new_name"
            ok "Using name: ${NAME}"
            return 0
          fi
        done
        ;;
      *)
        warn "Enter 1 or 2."
        ;;
    esac
  done
}

spinner_start() {
  SPINNER_MSG="$1"
  SPINNER_CHARS='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  SPINNER_PID=""
  (
    i=0
    while true; do
      char="${SPINNER_CHARS:$((i % ${#SPINNER_CHARS})):1}"
      printf "\r   ${CYAN}%s${RESET} %s..." "$char" "$SPINNER_MSG" >&2
      sleep 0.08
      i=$(( i + 1 ))
    done
  ) &
  SPINNER_PID=$!
}

spinner_stop() {
  if [[ -n "${SPINNER_PID:-}" ]]; then
    kill "$SPINNER_PID" 2>/dev/null || true
    wait "$SPINNER_PID" 2>/dev/null || true
    printf "\r\033[K" >&2
    SPINNER_PID=""
  fi
}

trap 'spinner_stop' EXIT

cleanup_temp() {
  spinner_stop
  if [[ -n "${TMPDIR_WORK:-}" && -d "$TMPDIR_WORK" ]]; then
    rm -rf "$TMPDIR_WORK" 2>/dev/null || true
    TMPDIR_WORK=""
  fi
}

# ── file classification ───────────────────────────────────────────────────────

SOURCE_ARCHIVE=false

_classify_file() {
  local file="$1" fname
  fname="$(basename "$file")"
  # Installer by name
  case "$fname" in
    install.sh|setup.sh|bootstrap.sh|installer.sh|install|setup)
      printf 'installer'; return ;;
  esac
  # ELF binary (magic bytes 7f 45 4c 46)
  local magic
  magic="$(od -An -N4 -tx1 "$file" 2>/dev/null | tr -d ' \n')"
  [[ "$magic" == "7f454c46" ]] && { printf 'binary'; return; }
  # Script: check shebang, then distinguish installer vs tool by content
  head -c2 "$file" 2>/dev/null | grep -q $'#!' || { printf 'binary'; return; }
  grep -qiE '\.(bashrc|zshrc|profile|bash_profile)|export [A-Z_]+=.*HOME|mkdir -p .*HOME' \
    "$file" 2>/dev/null && printf 'installer' || printf 'script'
}

# ── registry helpers ──────────────────────────────────────────────────────────
# Format: NAME <TAB> URL <TAB> INSTALL_PATH <TAB> TIMESTAMP

registry_ensure() {
  mkdir -p "$(dirname "$REGISTRY")"
  [[ -f "$REGISTRY" ]] || touch "$REGISTRY"
}

registry_add() {
  local name="$1" url="$2" path="$3"
  registry_ensure
  registry_remove_entry "$name"
  echo -e "${name}\t${url}\t${path}\t$(date '+%Y-%m-%d %H:%M:%S')" >> "$REGISTRY"
}

registry_remove_entry() {
  local name="$1"
  registry_ensure
  if [[ -f "$REGISTRY" ]]; then
    local tmpfile
    tmpfile="$(mktemp)"
    grep -v $'^'"${name}"$'\t' "$REGISTRY" > "$tmpfile" || true
    mv "$tmpfile" "$REGISTRY"
  fi
}

registry_lookup() {
  local name="$1"
  registry_ensure
  grep $'^'"${name}"$'\t' "$REGISTRY" 2>/dev/null | head -n 1 || true
}

registry_list() {
  registry_ensure
  if [[ ! -s "$REGISTRY" ]]; then
    echo -e "   ${DIM}No managed installs found.${RESET}"
    return
  fi

  printf "\n   %-20s %-25s %s\n" "NAME" "INSTALLED" "URL"
  printf "   %-20s %-25s %s\n" "────────────────────" "─────────────────────────" "───────────────────────────────"
  while IFS=$'\t' read -r name url path timestamp; do
    printf "   ${GREEN}%-20s${RESET} ${DIM}%-25s${RESET} %s\n" "$name" "$timestamp" "$url"
  done < "$REGISTRY"
  echo ""
}

# ── export / import helpers ───────────────────────────────────────────────────
rack_export() {
  local outfile="$1"
  registry_ensure
  if [[ -z "$outfile" ]]; then
    cat "$REGISTRY" 2>/dev/null || true
  else
    cp "$REGISTRY" "$outfile" 2>/dev/null || die "Failed to export to $outfile"
    ok "Exported registry to $outfile"
  fi
}

rack_import() {
  local infile="$1"
  [[ -f "$infile" ]] || die "Import file not found: $infile"
  registry_ensure
  # Simple merge: append non-dupe lines (by name)
  while IFS=$'\t' read -r name url path ts; do
    if ! grep -q $'^'"${name}"$'\t' "$REGISTRY" 2>/dev/null; then
      echo -e "${name}\t${url}\t${path}\t${ts}" >> "$REGISTRY"
    fi
  done < "$infile"
  ok "Imported/merged from $infile"
}

# ── history helpers ───────────────────────────────────────────────────────────
# Format: NAME <TAB> URL <TAB> TIMESTAMP
# Append-only; one entry per URL change (re-downloading same URL is silent)

history_append() {
  local name="$1" url="$2"
  mkdir -p "$(dirname "$HISTORY")"
  [[ -f "$HISTORY" ]] || touch "$HISTORY"
  printf '%s\t%s\t%s\n' "$name" "$url" "$(date '+%Y-%m-%d %H:%M:%S')" >> "$HISTORY"
}

# ── GitHub slug resolution ────────────────────────────────────────────────────

_gh_api_get() {
  local api_url="$1" outfile="$2"
  if command -v curl &>/dev/null; then
    curl -sf -H "Accept: application/vnd.github+json" \
         -H "X-GitHub-Api-Version: 2022-11-28" \
         -o "$outfile" "$api_url" 2>/dev/null
  elif command -v wget &>/dev/null; then
    wget -q --header="Accept: application/vnd.github+json" \
         -O "$outfile" "$api_url" 2>/dev/null
  else
    die "Neither curl nor wget found."
  fi
}

_gh_asset_urls() {
  grep -o '"browser_download_url": *"[^"]*"' "$1" | grep -o 'https://[^"]*'
}

_gh_tag_name() {
  grep -o '"tag_name": *"[^"]*"' "$1" | grep -o '"[^"]*"$' | tr -d '"' | head -n1
}

_gh_repo_names() {
  grep -o '"full_name": *"[^"]*"' "$1" | grep -o '"[^"]*"$' | tr -d '"'
}

PICK_RESULT=""
_pick_numbered() {
  local prompt="$1"; shift
  local -a items=("$@")
  local i=1 choice
  for item in "${items[@]}"; do
    printf "   ${CYAN}%3d)${RESET}  %s\n" "$i" "$item"
    ((i++))
  done
  echo ""
  while true; do
    printf "   ${BOLD}%s${RESET} " "$prompt"
    read -r choice < /dev/tty
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#items[@]} )); then
      PICK_RESULT="${items[$((choice-1))]}"
      return 0
    fi
    warn "Enter a number between 1 and ${#items[@]}."
  done
}

_gh_resolve_release() {
  local slug="$1" allow_search="${2:-true}"
  local json_file rc=0

  json_file="$(mktemp)"
  spinner_start "Fetching latest release for '${slug}'"
  _gh_api_get "https://api.github.com/repos/${slug}/releases/latest" "$json_file" || rc=$?
  spinner_stop

  if [[ $rc -ne 0 ]] || ! grep -q '"tag_name"' "$json_file" 2>/dev/null; then
    rm -f "$json_file"
    if [[ "$allow_search" == true ]]; then
      local bare="${slug##*/}"
      warn "No release found for '${slug}' — searching GitHub..."
      echo ""
      _gh_search_and_pick "$bare"
      return
    fi
    die "Could not fetch a release for '${slug}'. Verify the repo exists and has published releases."
  fi

  local tag
  tag="$(_gh_tag_name "$json_file")"
  ok "Found release: ${tag}"

  local -a ASSET_URLS
  mapfile -t ASSET_URLS < <(_gh_asset_urls "$json_file")
  rm -f "$json_file"

  if [[ "${#ASSET_URLS[@]}" -eq 0 ]]; then
    local _src_url="https://github.com/${slug}/archive/refs/tags/${tag}.tar.gz"
    warn "No release assets found — falling back to source archive"
    info "Source: ${_src_url}"
    URL="$_src_url"
    ARCHIVE_MODE=true
    SOURCE_ARCHIVE=true
    return
  fi

  # Auto-filter assets to the current platform before presenting the picker
  if [[ "${#ASSET_URLS[@]}" -gt 1 ]]; then
    _filter_assets "${ASSET_URLS[@]}"
    if [[ "${#_FILTERED_ASSETS[@]}" -gt 0 && "${#_FILTERED_ASSETS[@]}" -lt "${#ASSET_URLS[@]}" ]]; then
      info "Platform filter ($(uname -m)/$(uname -s | tr '[:upper:]' '[:lower:]')): ${#ASSET_URLS[@]} → ${#_FILTERED_ASSETS[@]} asset(s)"
      ASSET_URLS=("${_FILTERED_ASSETS[@]}")
    elif [[ "${#_FILTERED_ASSETS[@]}" -eq 0 ]]; then
      warn "No assets matched current platform — showing all ${#ASSET_URLS[@]}"
    fi
  fi

  if [[ "${#ASSET_URLS[@]}" -eq 1 ]]; then
    URL="${ASSET_URLS[0]}"
    ok "Single asset: $(basename "$URL")"
  else
    step "Select asset"
    info "Release ${tag} · ${#ASSET_URLS[@]} assets available for '${slug}'"
    echo ""
    [[ -t 0 ]] || die "Asset selection requires an interactive terminal."
    local -a basenames=()
    for u in "${ASSET_URLS[@]}"; do
      basenames+=("$(basename "$u")")
    done
    _pick_numbered "Asset number:" "${basenames[@]}"
    for u in "${ASSET_URLS[@]}"; do
      [[ "$(basename "$u")" == "$PICK_RESULT" ]] && { URL="$u"; break; }
    done
    ok "Selected: $(basename "$URL")"
  fi

  if [[ "$ARCHIVE_MODE" == false ]]; then
    local _f; _f="$(basename "$URL")"
    case "$_f" in
      *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) ARCHIVE_MODE=true ;;
    esac
  fi
}

_gh_search_and_pick() {
  local query="$1" rc=0
  local json_file

  step "Searching GitHub"
  info "Query: ${query}"

  local encoded; encoded="$(printf '%s' "$query" | sed 's/ /+/g')"
  json_file="$(mktemp)"
  spinner_start "Querying GitHub"
  _gh_api_get \
    "https://api.github.com/search/repositories?q=${encoded}&per_page=10&sort=stars&order=desc" \
    "$json_file" || rc=$?
  spinner_stop

  if [[ $rc -ne 0 ]]; then
    rm -f "$json_file"
    die "GitHub search failed for '${query}'. Check your connection or provide a full URL."
  fi

  local -A _seen_repos
  local -a REPO_NAMES=()
  while IFS= read -r rname; do
    [[ -z "${_seen_repos[$rname]+x}" ]] && { REPO_NAMES+=("$rname"); _seen_repos["$rname"]=1; }
  done < <(_gh_repo_names "$json_file")
  rm -f "$json_file"

  [[ "${#REPO_NAMES[@]}" -gt 0 ]] \
    || die "No GitHub repositories found matching '${query}'."

  ok "Found ${#REPO_NAMES[@]} matching repository(s)"
  echo ""

  local selected_repo
  if [[ "${#REPO_NAMES[@]}" -eq 1 ]]; then
    selected_repo="${REPO_NAMES[0]}"
    ok "Only match: ${selected_repo}"
  else
    [[ -t 0 ]] || die "Repository selection requires an interactive terminal."
    _pick_numbered "Repo number:" "${REPO_NAMES[@]}"
    selected_repo="$PICK_RESULT"
    ok "Selected: ${selected_repo}"
  fi

  echo ""
  _gh_resolve_release "$selected_repo" false
}

github_resolve_slug() {
  local input="$1"
  step "Resolving GitHub reference"
  info "Input: ${input}"
  if [[ "$input" =~ ^[a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+$ ]]; then
    _gh_resolve_release "$input" true
  else
    _gh_search_and_pick "$input"
  fi
}

# Extract owner/repo from a GitHub release download URL
_gh_slug_from_url() {
  [[ "$1" =~ github\.com/([^/]+/[^/]+)/releases/ ]] && printf '%s\n' "${BASH_REMATCH[1]}"
}

# Extract the release tag from a GitHub release download URL
_gh_tag_from_url() {
  [[ "$1" =~ github\.com/[^/]+/[^/]+/releases/download/([^/]+)/ ]] && printf '%s\n' "${BASH_REMATCH[1]}"
}

# Fetch the latest release tag for a slug. Outputs the tag to stdout; returns 1 on failure.
_gh_latest_tag_for_slug() {
  local slug="$1" rc=0 json_file
  json_file="$(mktemp)"
  _gh_api_get "https://api.github.com/repos/${slug}/releases/latest" "$json_file" || rc=$?
  if [[ $rc -ne 0 ]] || ! grep -q '"tag_name"' "$json_file" 2>/dev/null; then
    rm -f "$json_file"
    return 1
  fi
  local tag; tag="$(_gh_tag_name "$json_file")"
  rm -f "$json_file"
  printf '%s\n' "$tag"
}

# ── asset platform filtering ──────────────────────────────────────────────────
# Populates global _FILTERED_ASSETS from the URLs passed as arguments.
# Matches assets whose filename contains both an arch token and an OS token for
# the current platform (overridable with ARCH_FILTER). On Linux, musl builds are
# preferred over gnu when both are present.

_FILTERED_ASSETS=()

_filter_assets() {
  _FILTERED_ASSETS=()
  local _arch _os
  _arch="$(uname -m 2>/dev/null || true)"
  _os="$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]' || true)"

  local -a _arch_pats _os_pats
  if [[ -n "${ARCH_FILTER:-}" ]]; then
    _arch_pats=("$ARCH_FILTER")
  else
    case "$_arch" in
      x86_64)  _arch_pats=(x86_64 amd64) ;;
      aarch64) _arch_pats=(aarch64 arm64) ;;
      armv7l)  _arch_pats=(armv7 armhf arm) ;;
      i686)    _arch_pats=(i686 i386 386) ;;
      *)       _arch_pats=("$_arch") ;;
    esac
  fi
  case "$_os" in
    linux)  _os_pats=(linux) ;;
    darwin) _os_pats=(darwin macos) ;;
    *)      _os_pats=("$_os") ;;
  esac

  local _url _fname _ap _op _am _om
  for _url in "$@"; do
    _fname="$(basename "$_url" | tr '[:upper:]' '[:lower:]')"
    _am=false; for _ap in "${_arch_pats[@]}"; do [[ "$_fname" == *"$_ap"* ]] && { _am=true; break; }; done
    _om=false; for _op in "${_os_pats[@]}";   do [[ "$_fname" == *"$_op"* ]] && { _om=true; break; }; done
    [[ "$_am" == true && "$_om" == true ]] && _FILTERED_ASSETS+=("$_url")
  done

  # Prefer musl over gnu on Linux for static portability
  if [[ "$_os" == "linux" && "${#_FILTERED_ASSETS[@]}" -gt 1 ]]; then
    local -a _musl=()
    for _url in "${_FILTERED_ASSETS[@]}"; do
      [[ "$(basename "$_url" | tr '[:upper:]' '[:lower:]')" == *musl* ]] && _musl+=("$_url")
    done
    [[ "${#_musl[@]}" -gt 0 ]] && _FILTERED_ASSETS=("${_musl[@]}")
  fi

  # Prefer portable archives (.tar.gz .tar.xz .tar.bz2 .tgz .zip) over
  # system package formats (.deb .rpm .apk) — rack installs raw binaries
  if [[ "${#_FILTERED_ASSETS[@]}" -gt 1 ]]; then
    local -a _archives=()
    local _af
    for _url in "${_FILTERED_ASSETS[@]}"; do
      _af="$(basename "$_url" | tr '[:upper:]' '[:lower:]')"
      case "$_af" in
        *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) _archives+=("$_url") ;;
      esac
    done
    [[ "${#_archives[@]}" -gt 0 ]] && _FILTERED_ASSETS=("${_archives[@]}")
  fi
}

# Select the correct asset for an update. Tries to auto-match by replacing the old tag
# in the current filename; falls back to interactive picker if the filename changed.
# Sets global URL and ARCHIVE_MODE.
_gh_select_update_asset() {
  local slug="$1" old_tag="$2" new_tag="$3" old_url="$4"
  local json_file rc=0

  json_file="$(mktemp)"
  spinner_start "Fetching assets for ${slug} ${new_tag}"
  _gh_api_get "https://api.github.com/repos/${slug}/releases/latest" "$json_file" || rc=$?
  spinner_stop

  if [[ $rc -ne 0 ]] || ! grep -q '"tag_name"' "$json_file" 2>/dev/null; then
    rm -f "$json_file"
    die "Failed to fetch release assets for '${slug}'."
  fi

  local -a ASSET_URLS
  mapfile -t ASSET_URLS < <(_gh_asset_urls "$json_file")
  rm -f "$json_file"

  [[ "${#ASSET_URLS[@]}" -gt 0 ]] \
    || die "Release '${new_tag}' for '${slug}' has no downloadable assets."

  if [[ "${#ASSET_URLS[@]}" -eq 1 ]]; then
    URL="${ASSET_URLS[0]}"
    ok "Asset: $(basename "$URL")"
  else
    local old_fname; old_fname="$(basename "$old_url")"
    local new_fname; new_fname="${old_fname//${old_tag}/${new_tag}}"
    local matched=""
    for u in "${ASSET_URLS[@]}"; do
      [[ "$(basename "$u")" == "$new_fname" ]] && { matched="$u"; break; }
    done

    if [[ -n "$matched" ]]; then
      URL="$matched"
      ok "Auto-matched: $(basename "$URL")"
    else
      # Tag-substitution match failed; try platform filter before falling back to picker
      _filter_assets "${ASSET_URLS[@]}"
      if [[ "${#_FILTERED_ASSETS[@]}" -eq 1 ]]; then
        URL="${_FILTERED_ASSETS[0]}"
        ok "Platform-matched: $(basename "$URL")"
      else
        [[ "${#_FILTERED_ASSETS[@]}" -gt 1 ]] && ASSET_URLS=("${_FILTERED_ASSETS[@]}")
        step "Select asset for '${slug}' ${new_tag}"
        info "Asset filename changed — please select manually:"
        echo ""
        [[ -t 0 ]] || die "Asset selection requires an interactive terminal."
        local -a basenames=()
        for u in "${ASSET_URLS[@]}"; do
          basenames+=("$(basename "$u")")
        done
        _pick_numbered "Asset number:" "${basenames[@]}"
        for u in "${ASSET_URLS[@]}"; do
          [[ "$(basename "$u")" == "$PICK_RESULT" ]] && { URL="$u"; break; }
        done
        ok "Selected: $(basename "$URL")"
      fi
    fi
  fi

  if [[ "$ARCHIVE_MODE" == false ]]; then
    local _f; _f="$(basename "$URL")"
    case "$_f" in
      *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) ARCHIVE_MODE=true ;;
    esac
  fi
}

# ── download + install core ───────────────────────────────────────────────────
# Reads globals: NAME, URL, ARCHIVE_MODE, INSTALL_DIR, REGISTRY, HISTORY
_do_install() {
  local archive_name="${URL##*/}"
  archive_name="${archive_name%%\?*}"

  if [[ "${DRY_RUN:-false}" == true ]]; then
    step "Dry run — no downloads or filesystem changes will be performed"
    info "Would fetch: ${URL}"
    info "Would install: ${INSTALL_DIR}/${NAME}"
    [[ "$ARCHIVE_MODE" == true ]] && info "Archive mode: yes" || info "Direct binary mode"
    ok "Dry run complete (no changes made)"
    return 0
  fi

  TMPDIR_WORK="$(mktemp -d)"
  # RETURN trap ensures per-function cleanup even in update loops; EXIT trap remains for whole-script spinner safety
  trap 'cleanup_temp' RETURN
  local tmpfile="${TMPDIR_WORK}/${archive_name}"

  # ── download ─────────────────────────────────────────────────────────────
  step "Downloading"
  info "Source: ${URL}"
  info "Saving to temp: ${tmpfile}"
  echo ""

  if command -v wget &>/dev/null; then
    info "Using wget"
    echo ""
    wget --show-progress -q -O "$tmpfile" "$URL" || die "Download failed (wget) for ${URL}"
    echo ""
  elif command -v curl &>/dev/null; then
    info "Using curl"
    echo ""
    curl -L --progress-bar -o "$tmpfile" "$URL" || die "Download failed (curl) for ${URL}"
    echo ""
  else
    die "Neither wget nor curl found. Install one and try again."
  fi

  local filesize
  filesize="$(du -sh "$tmpfile" 2>/dev/null | cut -f1)"
  ok "Download complete (${filesize})"

  # Log SHA256 of what was downloaded (for manual verification / reproducibility)
  local sha256=""
  if command -v sha256sum &>/dev/null; then
    sha256="$(sha256sum "$tmpfile" 2>/dev/null | cut -d' ' -f1 || true)"
  elif command -v shasum &>/dev/null; then
    sha256="$(shasum -a 256 "$tmpfile" 2>/dev/null | cut -d' ' -f1 || true)"
  fi
  [[ -n "$sha256" ]] && info "SHA256: $sha256"

  # ── automatic verification if companion hash available ───────────────────
  if [[ -n "$sha256" ]]; then
    local sha_url="${URL}.sha256"
    local expected_sha=""
    local tmp_sha="${TMPDIR_WORK}/$(basename "$URL").sha256"
    if command -v wget &>/dev/null; then
      wget -q -O "$tmp_sha" "$sha_url" 2>/dev/null || true
    elif command -v curl &>/dev/null; then
      curl -sL -o "$tmp_sha" "$sha_url" 2>/dev/null || true
    fi
    if [[ -f "$tmp_sha" ]]; then
      expected_sha="$(cut -d' ' -f1 < "$tmp_sha" 2>/dev/null | tr -d '\n')"
      if [[ "$expected_sha" == "$sha256" ]]; then
        ok "SHA256 verified against ${URL}.sha256"
      else
        warn "SHA256 mismatch! Expected $expected_sha got $sha256"
        # continue but warn; could die in strict mode but keep simple
      fi
    fi
    rm -f "$tmp_sha" 2>/dev/null || true
  fi

  # ── archive extraction ────────────────────────────────────────────────────
  if [[ "$ARCHIVE_MODE" == true ]]; then
    step "Extracting archive"
    info "Archive: ${archive_name}"

    local extract_dir="${TMPDIR_WORK}/extracted"
    mkdir -p "$extract_dir"

    local format
    spinner_start "Extracting"
    case "$archive_name" in
      *.tar.gz|*.tgz)  tar -xzf "$tmpfile" -C "$extract_dir"; format="tar.gz" ;;
      *.tar.bz2)       tar -xjf "$tmpfile" -C "$extract_dir"; format="tar.bz2" ;;
      *.tar.xz)        tar -xJf "$tmpfile" -C "$extract_dir"; format="tar.xz" ;;
      *.zip)
        command -v unzip &>/dev/null || { spinner_stop; die "'unzip' not found. Install it and try again."; }
        unzip -q "$tmpfile" -d "$extract_dir"
        format="zip"
        ;;
      *)
        spinner_stop
        die "Unrecognised archive format: '${archive_name}'. Supported: .tar.gz .tgz .tar.bz2 .tar.xz .zip"
        ;;
    esac
    spinner_stop
    ok "Extracted (${format})"

    info "Archive contents (top level):"
    find "$extract_dir" -maxdepth 2 | sed "s|${extract_dir}||" | sed '/^$/d' \
      | while IFS= read -r line; do echo -e "      ${DIM}${line}${RESET}"; done

    step "Locating binary"

    local binary=""
    spinner_start "Searching for '${NAME}'"
    binary="$(find "$extract_dir" -type f -name "$NAME" | head -n 1)"
    spinner_stop

    if [[ -n "$binary" ]]; then
      ok "Found exact match: ${binary#"$extract_dir"}"
    elif [[ "$SOURCE_ARCHIVE" == true ]]; then
      warn "No file named '${NAME}' found in source archive"
      local _iname
      for _iname in install.sh setup.sh bootstrap.sh installer.sh install setup; do
        binary="$(find "$extract_dir" -type f -name "$_iname" | head -n 1)"
        [[ -n "$binary" ]] && { info "Found: ${_iname}"; break; }
      done
      if [[ -z "$binary" ]]; then
        warn "No installer script found — falling back to first executable..."
        spinner_start "Scanning for executables"
        binary="$(find "$extract_dir" -type f -perm /111 | head -n 1)"
        spinner_stop
        [[ -n "$binary" ]] || die "No executable found in source archive. You may need to inspect it manually."
        warn "Using: $(basename "$binary")"
      fi
    else
      warn "No file named '${NAME}' found — scanning for best match..."
      spinner_start "Scanning for executables"

      # 1. Name-prefix match, excluding scripts and man pages (e.g. yq → yq_linux_amd64)
      binary="$(find "$extract_dir" -type f -perm /111 -name "${NAME}*" \
        ! -name "*.sh" ! -name "*.py" ! -name "*.rb" ! -name "*.1" | head -n 1)"

      if [[ -z "$binary" ]]; then
        # 2. Exclude installer scripts; prefer ELF binaries over plain scripts
        local _f _magic
        while IFS= read -r _f; do
          _magic="$(od -An -N4 -tx1 "$_f" 2>/dev/null | tr -d ' \n')"
          [[ "$_magic" == "7f454c46" ]] && { binary="$_f"; break; }
        done < <(find "$extract_dir" -type f -perm /111 \
          ! -name "install*" ! -name "setup*" ! -name "bootstrap*")
        # 3. Any non-installer executable as last resort
        [[ -z "$binary" ]] && binary="$(find "$extract_dir" -type f -perm /111 \
          ! -name "install*" ! -name "setup*" ! -name "bootstrap*" | head -n 1)"
      fi

      spinner_stop

      if [[ -n "$binary" ]]; then
        warn "Using: $(basename "$binary") → will be installed as '${NAME}'"
      else
        die "No executable binary found in archive. You may need to inspect it manually."
      fi
    fi

    if [[ "$SOURCE_ARCHIVE" == true ]]; then
      local _fclass
      spinner_start "Classifying '$(basename "$binary")'"
      _fclass="$(_classify_file "$binary")"
      spinner_stop
      ok "File type: ${_fclass}"

      if [[ "$_fclass" == "installer" ]]; then
        step "Installer script detected"
        info "$(basename "$binary") manages its own installation"
        echo ""
        if [[ -t 0 ]]; then
          echo -en "   ${BOLD}Run installer? [Y/n]${RESET} "
          read -r _run_confirm < /dev/tty
          [[ "$_run_confirm" =~ ^[Nn]$ ]] && { echo -e "\n   ${DIM}Aborted.${RESET}\n"; exit 0; }
        fi
        echo ""
        chmod +x "$binary"
        ( cd "$(dirname "$binary")" && bash "$(basename "$binary")" )
        echo ""
        echo -e "${GREEN}${BOLD}✔ Installer finished.${RESET}"
        echo -e "   ${DIM}Note: rack cannot track or update installs run by external installer scripts.${RESET}"
        echo ""
        exit 0
      fi
    fi

    spinner_start "Copying binary"
    cp "$binary" "${INSTALL_DIR}/${NAME}"
    spinner_stop
    ok "Binary copied to install dir"

  else
    step "Installing binary"
    spinner_start "Copying"
    cp "$tmpfile" "${INSTALL_DIR}/${NAME}"
    spinner_stop
    ok "Binary copied to install dir"
  fi

  # ── chmod ──────────────────────────────────────────────────────────────────
  step "Setting permissions"
  spinner_start "chmod +x"
  chmod +x "${INSTALL_DIR}/${NAME}"
  spinner_stop
  ok "Marked as executable"

  # ── optional post-install hook ─────────────────────────────────────────────
  local hook="$HOME/.config/rack/hooks/post-install"
  if [[ -x "$hook" ]]; then
    "$hook" "${INSTALL_DIR}/${NAME}" "$NAME" "$URL" || warn "post-install hook failed (non-fatal)"
  fi

  # ── registry & history ─────────────────────────────────────────────────────
  step "Updating registry"
  local _cur_entry _cur_url
  _cur_entry="$(registry_lookup "$NAME")"
  _cur_url="$(printf '%s' "$_cur_entry" | cut -f2)"
  spinner_start "Recording install"
  [[ -z "$_cur_entry" || "$URL" != "$_cur_url" ]] && history_append "$NAME" "$URL"
  registry_add "$NAME" "$URL" "${INSTALL_DIR}/${NAME}"
  spinner_stop
  ok "Registered: ${REGISTRY}"

  # Prompt cleanup on success path (RETURN trap also handles)
  cleanup_temp
}

# ── global option defaults (must precede 'rack update' block) ─────────────────
YES_MODE=false
DRY_RUN=false
ARCH_FILTER=""

# ── 'rack update' subcommand ─────────────────────────────────────────────────
if [[ "${1:-}" == "update" ]]; then
  for _upd_arg in "${@:2}"; do
    [[ "$_upd_arg" == "-y" || "$_upd_arg" == "--yes" ]] && YES_MODE=true
    [[ "$_upd_arg" == "-n" || "$_upd_arg" == "--dry-run" ]] && DRY_RUN=true
  done
  echo -e "\n${BOLD}rack update — checking managed installs for updates${RESET}"

  step "Loading registry"
  registry_ensure
  info "Registry: ${REGISTRY}"
  if [[ ! -s "$REGISTRY" ]]; then
    warn "Registry is empty — nothing to update."
    echo ""
    exit 0
  fi
  TOTAL="$(grep -c '' "$REGISTRY" 2>/dev/null || true)"
  ok "Found ${TOTAL} managed install(s)"

  step "Checking for updates"
  info "Querying GitHub releases API for each install..."
  echo ""

  declare -a UPD_NAMES=()
  declare -a UPD_SLUGS=()
  declare -a UPD_OLD_TAGS=()
  declare -a UPD_NEW_TAGS=()
  declare -a UPD_OLD_URLS=()
  UPTODATE_COUNT=0
  SKIP_COUNT=0

  while IFS=$'\t' read -r reg_name reg_url reg_path reg_ts; do
    slug="$(_gh_slug_from_url "$reg_url")"
    if [[ -z "$slug" ]]; then
      printf "   ${DIM}~  %-20s non-GitHub URL — skipped${RESET}\n" "$reg_name"
      ((SKIP_COUNT++)) || true
      continue
    fi

    cur_tag="$(_gh_tag_from_url "$reg_url")"
    if [[ -z "$cur_tag" ]]; then
      printf "   ${DIM}~  %-20s could not parse version — skipped${RESET}\n" "$reg_name"
      ((SKIP_COUNT++)) || true
      continue
    fi

    spinner_start "Checking ${reg_name} (${cur_tag})"
    latest_tag="$(_gh_latest_tag_for_slug "$slug")" || {
      spinner_stop
      printf "   ${YELLOW}⚠${RESET}  %-20s ${DIM}API error — skipped${RESET}\n" "$reg_name"
      ((SKIP_COUNT++)) || true
      continue
    }
    spinner_stop

    # Fetch release notes for better diffing (simple body)
    local notes=""
    if command -v curl &>/dev/null; then
      notes=$(curl -s -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/${slug}/releases/tags/${latest_tag}" 2>/dev/null | \
        grep -o '"body": *"[^"]*"' | head -1 | cut -d'"' -f4 | head -c 200 || true)
    fi
    [[ -n "$notes" ]] && info "Release notes: ${notes}..." || true

    if [[ "$latest_tag" == "$cur_tag" ]]; then
      printf "   ${GREEN}✔${RESET}  %-20s ${DIM}${cur_tag} — up to date${RESET}\n" "$reg_name"
      ((UPTODATE_COUNT++)) || true
    else
      printf "   ${YELLOW}↑${RESET}  %-20s ${DIM}${cur_tag}${RESET} → ${CYAN}${latest_tag}${RESET}\n" \
        "$reg_name"
      UPD_NAMES+=("$reg_name")
      UPD_SLUGS+=("$slug")
      UPD_OLD_TAGS+=("$cur_tag")
      UPD_NEW_TAGS+=("$latest_tag")
      UPD_OLD_URLS+=("$reg_url")
    fi
  done < "$REGISTRY"

  echo ""

  if [[ "${#UPD_NAMES[@]}" -eq 0 ]]; then
    echo -e "${GREEN}${BOLD}✔ All installs are up to date.${RESET}"
    [[ "$SKIP_COUNT" -gt 0 ]] \
      && echo -e "   ${DIM}(${SKIP_COUNT} skipped — non-GitHub or unresolvable)${RESET}"
    echo ""
    exit 0
  fi

  echo -e "${YELLOW}${BOLD}${#UPD_NAMES[@]} update(s) available:${RESET}"
  echo ""
  printf "   %-20s  %-15s  %s\n" "BINARY" "CURRENT" "LATEST"
  printf "   %-20s  %-15s  %s\n" "────────────────────" "───────────────" "───────────────"
  for i in "${!UPD_NAMES[@]}"; do
    printf "   ${BOLD}%-20s${RESET}  ${DIM}%-15s${RESET}  ${CYAN}%s${RESET}\n" \
      "${UPD_NAMES[$i]}" "${UPD_OLD_TAGS[$i]}" "${UPD_NEW_TAGS[$i]}"
  done
  echo ""
  [[ "$UPTODATE_COUNT" -gt 0 ]] \
    && echo -e "   ${DIM}${UPTODATE_COUNT} already up to date.${RESET}"
  [[ "$SKIP_COUNT" -gt 0 ]] \
    && echo -e "   ${DIM}${SKIP_COUNT} skipped (non-GitHub or unresolvable).${RESET}"
  echo ""

  if [[ "$YES_MODE" == true ]]; then
    ok "Auto-confirming (-y)"
    CONFIRM="y"
  elif [[ ! -t 0 ]]; then
    echo -e "   ${DIM}Non-interactive — skipping update prompt.${RESET}"
    echo ""
    exit 0
  else
    echo -en "   ${BOLD}Apply all updates? [y/N]${RESET} "
    read -r CONFIRM < /dev/tty
    [[ "$CONFIRM" =~ ^[Yy]$ ]] || {
      echo -e "\n   ${DIM}Aborted. Nothing was changed.${RESET}\n"
      exit 0
    }
  fi

  for i in "${!UPD_NAMES[@]}"; do
    NAME="${UPD_NAMES[$i]}"
    SLUG="${UPD_SLUGS[$i]}"
    OLD_TAG="${UPD_OLD_TAGS[$i]}"
    NEW_TAG="${UPD_NEW_TAGS[$i]}"
    OLD_URL="${UPD_OLD_URLS[$i]}"

    echo ""
    echo -e "${BOLD}── ${NAME}  ${DIM}${OLD_TAG} → ${CYAN}${NEW_TAG}${RESET}${BOLD} ─${RESET}"

    step "Selecting asset"
    ARCHIVE_MODE=false
    SOURCE_ARCHIVE=false
    _gh_select_update_asset "$SLUG" "$OLD_TAG" "$NEW_TAG" "$OLD_URL"

    step "Checking install directory"
    mkdir -p "$INSTALL_DIR"
    ok "Install dir: ${INSTALL_DIR}"

    if [[ "$DRY_RUN" == true ]]; then
      info "DRY RUN: would update ${NAME} ${OLD_TAG} → ${NEW_TAG}"
    else
      _do_install
    fi

    echo ""
    echo -e "   ${GREEN}✔${RESET} ${BOLD}${NAME}${RESET} updated  ${DIM}${OLD_TAG} → ${CYAN}${NEW_TAG}${RESET}"
  done

  echo ""
  if [[ "$DRY_RUN" == true ]]; then
    echo -e "${YELLOW}${BOLD}Dry run complete — no updates were applied.${RESET}"
  else
    echo -e "${GREEN}${BOLD}✔ All updates applied.${RESET}"
  fi
  echo ""
  exit 0
fi

# ── flag parsing ──────────────────────────────────────────────────────────────
ARCHIVE_MODE=false
SOURCE_ARCHIVE=false
REMOVE_MODE=false
LIST_MODE=false
UPDATE_MODE=false
ROLLBACK_MODE=false
HISTORY_MODE=false
# YES_MODE and ARCH_FILTER already initialised above

while getopts ":aRluHrA:yn" opt; do
  case $opt in
    a) ARCHIVE_MODE=true ;;
    A) ARCH_FILTER="$OPTARG" ;;
    R) REMOVE_MODE=true ;;
    l) LIST_MODE=true ;;
    u) UPDATE_MODE=true ;;
    r) ROLLBACK_MODE=true ;;
    H) HISTORY_MODE=true ;;
    y) YES_MODE=true ;;
    n) DRY_RUN=true ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

# ── export / import subcommands (simple positional) ───────────────────────────
if [[ "${1:-}" == "export" ]]; then
  rack_export "${2:-}"
  exit 0
elif [[ "${1:-}" == "import" ]]; then
  [[ -n "${2:-}" ]] || die "import requires file"
  rack_import "$2"
  exit 0
fi

# ── list mode ─────────────────────────────────────────────────────────────────
if [[ "$LIST_MODE" == true ]]; then
  echo -e "\n${BOLD}rack — managed installs${RESET}"

  step "Locating registry"
  registry_ensure
  info "Registry: ${REGISTRY}"
  if [[ -f "$REGISTRY" ]]; then
    ok "Registry found"
  else
    warn "Registry does not exist yet — nothing has been installed."
    echo ""
    exit 0
  fi

  step "Reading entries"
  TOTAL="$(grep -c '' "$REGISTRY" 2>/dev/null || true)"
  if [[ "$TOTAL" -eq 0 ]]; then
    warn "Registry is empty — no managed installs recorded."
    echo ""
    exit 0
  fi
  ok "Found ${TOTAL} managed install(s)"

  step "Verifying installs on disk"
  MISSING=0
  while IFS=$'\t' read -r name url path timestamp; do
    if [[ -f "$path" ]]; then
      FILESIZE="$(du -sh "$path" 2>/dev/null | cut -f1)"
      ok "${name}  ${DIM}(${FILESIZE})${RESET}"
      info "Path:      ${path}"
      info "Source:    ${url}"
      info "Installed: ${timestamp}"
    else
      warn "${name}  ${RED}(missing from disk)${RESET}"
      info "Expected:  ${path}"
      info "Source:    ${url}"
      info "Installed: ${timestamp}"
      ((MISSING++)) || true
    fi
  done < "$REGISTRY"

  echo ""
  if [[ "$MISSING" -gt 0 ]]; then
    echo -e "${YELLOW}${BOLD}⚠ ${MISSING} install(s) missing from disk.${RESET}"
    echo -e "   Run ${BOLD}rack -R <name>${RESET} to clean up stale registry entries."
  else
    echo -e "${GREEN}${BOLD}✔ All installs verified on disk.${RESET}"
  fi
  echo ""
  exit 0
fi

# ── history mode ──────────────────────────────────────────────────────────────
if [[ "$HISTORY_MODE" == true ]]; then
  [[ $# -lt 1 ]] && die "History mode requires a name. Usage: rack -H <name>"

  NAME="$1"

  echo -e "\n${BOLD}rack — URL history for '${NAME}'${RESET}"

  step "Validating arguments"
  validate_name "$NAME"
  ok "Name: ${NAME}"

  step "Reading history"
  info "History file: ${HISTORY}"

  if [[ ! -f "$HISTORY" ]]; then
    warn "No history file found — nothing has been installed yet."
    echo ""
    exit 0
  fi

  mapfile -t HIST_ENTRIES < <(grep $'^'"${NAME}"$'\t' "$HISTORY" 2>/dev/null || true)
  HIST_COUNT="${#HIST_ENTRIES[@]}"

  if [[ "$HIST_COUNT" -eq 0 ]]; then
    warn "No history found for '${NAME}'."
    echo ""
    exit 0
  fi

  ok "Found ${HIST_COUNT} URL(s) in history"

  CUR_ENTRY="$(registry_lookup "$NAME")"
  CUR_URL="$(printf '%s' "$CUR_ENTRY" | cut -f2)"

  echo ""
  printf "   %-5s  %-19s  %s\n" "INDEX" "INSTALLED" "URL"
  printf "   %-5s  %-19s  %s\n" "─────" "───────────────────" "───────────────────────────────"

  idx=1
  for entry in "${HIST_ENTRIES[@]}"; do
    url="$(printf '%s' "$entry" | cut -f2)"
    timestamp="$(printf '%s' "$entry" | cut -f3)"
    if [[ -n "$CUR_URL" && "$url" == "$CUR_URL" ]]; then
      printf "   ${CYAN}%-5s${RESET}  ${DIM}%-19s${RESET}  %s  ${DIM}← current${RESET}\n" \
        "$idx" "$timestamp" "$url"
    else
      printf "   ${CYAN}%-5s${RESET}  ${DIM}%-19s${RESET}  %s\n" "$idx" "$timestamp" "$url"
    fi
    ((idx++))
  done

  echo ""
  if [[ "$HIST_COUNT" -gt 1 ]]; then
    echo -e "   Roll back with: ${BOLD}rack -r ${NAME} <index>${RESET}"
  fi
  echo ""
  exit 0
fi

# ── rollback mode ─────────────────────────────────────────────────────────────
if [[ "$ROLLBACK_MODE" == true ]]; then
  [[ $# -lt 2 ]] && die "Rollback mode requires a name and index. Usage: rack -r <name> <index>"

  NAME="$1"
  INDEX="$2"

  echo -e "\n${BOLD}rack — rolling back '${NAME}'${RESET}"

  step "Validating arguments"
  validate_name "$NAME"
  ok "Name: ${NAME}"

  [[ "$INDEX" =~ ^[0-9]+$ && "$INDEX" -gt 0 ]] \
    || die "Index must be a positive integer. Usage: rack -r ${NAME} <index>"
  ok "Index: ${INDEX}"

  step "Reading history"
  info "History file: ${HISTORY}"

  [[ -f "$HISTORY" ]] \
    || die "No history file found. Has '${NAME}' been installed before?"

  mapfile -t HIST_ENTRIES < <(grep $'^'"${NAME}"$'\t' "$HISTORY" 2>/dev/null || true)
  HIST_COUNT="${#HIST_ENTRIES[@]}"

  [[ "$HIST_COUNT" -gt 0 ]] \
    || die "No history found for '${NAME}'. Has it been installed before?"

  ok "Found ${HIST_COUNT} URL(s) in history"

  [[ "$INDEX" -le "$HIST_COUNT" ]] \
    || die "Index ${INDEX} out of range — history has ${HIST_COUNT} entry(s). Run: rack -H ${NAME}"

  TARGET_URL="$(printf '%s' "${HIST_ENTRIES[$((INDEX-1))]}" | cut -f2)"
  TARGET_TS="$(printf '%s' "${HIST_ENTRIES[$((INDEX-1))]}" | cut -f3)"
  ok "Target URL (index ${INDEX}): ${TARGET_URL}"
  info "Recorded: ${TARGET_TS}"

  CUR_ENTRY="$(registry_lookup "$NAME")"
  if [[ -n "$CUR_ENTRY" ]]; then
    CUR_URL="$(printf '%s' "$CUR_ENTRY" | cut -f2)"
    if [[ "$TARGET_URL" == "$CUR_URL" ]]; then
      warn "This is already the active URL — will re-download and reinstall."
    else
      warn "Currently active: ${CUR_URL}"
    fi
  else
    warn "'${NAME}' not currently in registry — will install fresh."
  fi

  URL="$TARGET_URL"

  # Auto-detect archive mode from URL filename if -a not explicitly set
  if [[ "$ARCHIVE_MODE" == false ]]; then
    _fname="${URL##*/}"
    _fname="${_fname%%\?*}"
    case "$_fname" in
      *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) ARCHIVE_MODE=true ;;
    esac
  fi

  [[ "$ARCHIVE_MODE" == true ]] \
    && ok "Mode: archive extraction" \
    || ok "Mode: direct binary"

  step "Checking install directory"
  mkdir -p "$INSTALL_DIR"
  ok "Install dir: ${INSTALL_DIR}"

  _do_install

  echo ""
  echo -e "${GREEN}${BOLD}✔ Done!${RESET}"
  echo -e "   ${BOLD}${NAME}${RESET} rolled back to URL #${INDEX} → ${INSTALL_DIR}/${NAME}"
  echo -e "   Run it with: ${BOLD}${NAME}${RESET}"
  echo ""
  exit 0
fi

# ── update mode ───────────────────────────────────────────────────────────────
if [[ "$UPDATE_MODE" == true ]]; then
  [[ $# -lt 1 ]] && die "Update mode requires a name. Usage: rack -u <name> [new-url]"

  NAME="$1"
  ALT_URL="${2:-}"

  echo -e "\n${BOLD}rack — updating '${NAME}'${RESET}"

  step "Validating arguments"
  validate_name "$NAME"
  ok "Name: ${NAME}"

  step "Checking registry"
  info "Registry: ${REGISTRY}"
  spinner_start "Looking up '${NAME}'"
  ENTRY="$(registry_lookup "$NAME")"
  spinner_stop

  [[ -n "$ENTRY" ]] \
    || die "'${NAME}' is not managed by rack. Install it first with: rack ${NAME} <url>"

  STORED_URL="$(echo "$ENTRY" | cut -f2)"
  INSTALLED_AT="$(echo "$ENTRY" | cut -f4)"
  ok "Registry entry found"
  info "Installed: ${INSTALLED_AT}"
  info "Recorded URL: ${STORED_URL}"

  if [[ -n "$ALT_URL" ]]; then
    if [[ "$ALT_URL" =~ ^https?:// ]]; then
      if [[ "$ALT_URL" =~ ^https://github\.com/([a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+)/?$ ]]; then
        github_resolve_slug "${BASH_REMATCH[1]}"
      else
        URL="$ALT_URL"
        if [[ "$ARCHIVE_MODE" == false ]]; then
          _fname="${URL##*/}"; _fname="${_fname%%\?*}"
          case "$_fname" in *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) ARCHIVE_MODE=true ;; esac
        fi
      fi
    else
      github_resolve_slug "$ALT_URL"
    fi
    warn "Using alternative URL (registry will be updated)"
    info "Old: ${STORED_URL}"
    info "New: ${URL}"
  else
    URL="$STORED_URL"
    ok "Using recorded URL"
  fi

  # Auto-detect archive mode from URL filename if -a not explicitly set
  if [[ "$ARCHIVE_MODE" == false ]]; then
    _fname="${URL##*/}"
    _fname="${_fname%%\?*}"
    case "$_fname" in
      *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) ARCHIVE_MODE=true ;;
    esac
  fi

  [[ "$ARCHIVE_MODE" == true ]] \
    && ok "Mode: archive extraction" \
    || ok "Mode: direct binary"

  step "Checking install directory"
  mkdir -p "$INSTALL_DIR"
  ok "Install dir: ${INSTALL_DIR}"

  _do_install

  echo ""
  echo -e "${GREEN}${BOLD}✔ Done!${RESET}"
  echo -e "   ${BOLD}${NAME}${RESET} has been updated → ${INSTALL_DIR}/${NAME}"
  [[ -n "$ALT_URL" ]] && echo -e "   Registry updated with new source URL."
  echo -e "   Run it with: ${BOLD}${NAME}${RESET}"
  echo ""
  exit 0
fi

# ── remove mode ───────────────────────────────────────────────────────────────
if [[ "$REMOVE_MODE" == true ]]; then
  [[ $# -lt 1 ]] && die "Remove mode requires a name. Usage: rack -R <name>"

  NAME="$1"

  echo -e "\n${BOLD}rack — removing '${NAME}'${RESET}"

  # ── validate name ───────────────────────────────────────────────────────
  step "Validating arguments"
  validate_name "$NAME"
  ok "Name: ${NAME}"
  ok "Mode: remove (-R)"

  if [[ "$DRY_RUN" == true ]]; then
    info "DRY RUN: would remove ${NAME} (from registry + disk if present)"
    ok "Dry run — no changes made"
    echo ""
    exit 0
  fi

  # ── lookup in registry ──────────────────────────────────────────────────
  step "Checking registry"
  info "Registry: ${REGISTRY}"
  spinner_start "Looking up '${NAME}'"
  ENTRY="$(registry_lookup "$NAME")"
  spinner_stop

  if [[ -n "$ENTRY" ]]; then
    INSTALL_PATH="$(echo "$ENTRY" | cut -f3)"
    SOURCE_URL="$(echo "$ENTRY"  | cut -f2)"
    INSTALLED_AT="$(echo "$ENTRY" | cut -f4)"
    ok "Registry entry found"
    info "Install path: ${INSTALL_PATH}"
    info "Source URL:   ${SOURCE_URL}"
    info "Installed at: ${INSTALLED_AT}"
  else
    warn "No registry entry for '${NAME}'"
    warn "Will attempt to remove from default install dir anyway: ${INSTALL_DIR}/${NAME}"
    INSTALL_PATH="${INSTALL_DIR}/${NAME}"
    SOURCE_URL="(unknown — not in registry)"
    INSTALLED_AT="(unknown)"
  fi

  # ── verify on disk ──────────────────────────────────────────────────────
  step "Verifying target on disk"
  info "Target: ${INSTALL_PATH}"

  if [[ -f "$INSTALL_PATH" ]]; then
    FILESIZE="$(du -sh "$INSTALL_PATH" 2>/dev/null | cut -f1)"
    ok "File exists (${FILESIZE})"
  else
    warn "File not found at '${INSTALL_PATH}' — nothing to delete on disk."
    if [[ -n "$ENTRY" ]]; then
      step "Cleaning up stale registry entry"
      spinner_start "Removing entry for '${NAME}'"
      registry_remove_entry "$NAME"
      spinner_stop
      ok "Stale registry entry removed"
    fi
    echo ""
    echo -e "${YELLOW}${BOLD}⚠ Nothing removed from disk${RESET} (file was already gone)"
    echo ""
    exit 0
  fi

  # ── confirm ─────────────────────────────────────────────────────────────
  step "Confirming removal"
  info "Binary:  ${INSTALL_PATH}"
  info "Source:  ${SOURCE_URL}"
  if [[ -t 0 ]]; then
    echo ""
    echo -e "   ${YELLOW}This will permanently delete ${BOLD}${NAME}${RESET}${YELLOW} from ${INSTALL_PATH}.${RESET}"
    echo -en "   ${YELLOW}Continue? [y/N]${RESET} "
    read -r CONFIRM
    [[ "$CONFIRM" =~ ^[Yy]$ ]] || { echo -e "\n   ${DIM}Aborted. Nothing was changed.${RESET}\n"; exit 0; }
    ok "Confirmed"
  else
    info "Non-interactive mode — skipping confirmation prompt"
  fi

  # ── delete binary ───────────────────────────────────────────────────────
  step "Removing binary"
  info "Deleting: ${INSTALL_PATH}"
  spinner_start "Removing file"
  rm -f "$INSTALL_PATH"
  spinner_stop
  ok "Deleted: ${INSTALL_PATH}"

  # ── clean registry ──────────────────────────────────────────────────────
  step "Updating registry"
  info "Registry: ${REGISTRY}"
  spinner_start "Removing entry for '${NAME}'"
  registry_remove_entry "$NAME"
  spinner_stop
  ok "Registry entry removed"
  REMAINING="$(grep -c '' "$REGISTRY" 2>/dev/null || true)"
  info "${REMAINING} install(s) remaining in registry"

  # ── summary ─────────────────────────────────────────────────────────────
  echo ""
  echo -e "${GREEN}${BOLD}✔ Done!${RESET}"
  echo -e "   ${BOLD}${NAME}${RESET} has been removed."
  echo -e "   It was originally installed from: ${DIM}${SOURCE_URL}${RESET}"
  echo -e "   Reinstall with: ${BOLD}rack ${NAME} <url>${RESET}"
  echo ""
  exit 0
fi

# ── install mode: require name + url ─────────────────────────────────────────
[[ $# -lt 2 ]] && usage

NAME="$1"
URL="$2"

# ── validation ────────────────────────────────────────────────────────────────
step "Validating arguments"

validate_name "$NAME"
ok "Name:  ${NAME}"

if [[ "$URL" =~ ^https?:// ]]; then
  if [[ "$URL" =~ ^https://github\.com/([a-zA-Z0-9._-]+/[a-zA-Z0-9._-]+)/?$ ]]; then
    github_resolve_slug "${BASH_REMATCH[1]}"
  else
    ok "URL:   ${URL}"
    if [[ "$ARCHIVE_MODE" == false ]]; then
      _fname="${URL##*/}"; _fname="${_fname%%\?*}"
      case "$_fname" in *.tar.gz|*.tgz|*.tar.bz2|*.tar.xz|*.zip) ARCHIVE_MODE=true ;; esac
    fi
  fi
elif [[ -n "$URL" ]]; then
  github_resolve_slug "$URL"
  ok "Resolved: ${URL}"
else
  die "Provide a URL (https://...) or a GitHub slug (owner/repo or a repo name)."
fi

[[ "$ARCHIVE_MODE" == true ]] \
  && ok "Mode:  archive extraction (-a)" \
  || ok "Mode:  direct binary install"

# ── install dir setup ─────────────────────────────────────────────────────────
step "Checking install directory"

mkdir -p "$INSTALL_DIR"
ok "Install dir: ${INSTALL_DIR}"

if [[ ":$PATH:" != *":${INSTALL_DIR}:"* ]]; then
  warn "'${INSTALL_DIR}' is not in your PATH."
  warn "Add this to your ~/.bashrc or ~/.zshrc:"
  echo -e "      ${DIM}export PATH=\"\$HOME/.local/bin:\$PATH\"${RESET}"
else
  ok "Install dir is in PATH"
fi

resolve_name_conflict
ok "Install name: ${NAME}"

if [[ -f "${INSTALL_DIR}/${NAME}" ]]; then
  EXISTING_ENTRY="$(registry_lookup "$NAME")"
  if [[ -n "$EXISTING_ENTRY" ]]; then
    warn "'${NAME}' was previously installed by rack — it will be overwritten."
    info "Original source: $(echo "$EXISTING_ENTRY" | cut -f2)"
  else
    warn "'${NAME}' already exists at ${INSTALL_DIR}/${NAME} — it will be overwritten."
  fi
fi

_do_install

# ── summary ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}${BOLD}✔ Done!${RESET}"
echo -e "   Installed ${BOLD}${NAME}${RESET} → ${INSTALL_DIR}/${NAME}"
echo -e "   Remove later with: ${BOLD}rack -R ${NAME}${RESET}"
echo -e "   Run it with: ${BOLD}${NAME}${RESET}"
echo ""
